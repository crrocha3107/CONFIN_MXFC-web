@*
8. IDENTIFICAÇÃO DO CÓDIGO
======================================
Nome do arquivo: DbTools.razor
Substitui: DbToolsForm.vb / .Designer.vb
VERSÃO: 1.0.0 (Migração Web - Gestão de Banco de Dados)
=======================================
*@
@page "/admin/dbtools"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject IJSRuntime JS
@attribute [Authorize(Roles = "PROGRAMADOR")]

<PageTitle>Ferramentas do Banco de Dados</PageTitle>

<div class="container-fluid py-3" style="max-width: 800px; margin: 0 auto;">
    <h3 class="fw-bold mb-4" style="color: #104E6E;">
        <i class="oi oi-cog me-2"></i> Ferramentas Administrativas (SQLite)
    </h3>

    <div class="row g-4">
        <!-- Card de Backup -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 text-center">
                    <i class="oi oi-data-transfer-download text-success mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold">Backup do Banco</h5>
                    <p class="text-muted small">Faz o download do arquivo atual do banco de dados (SQLite) para armazenamento seguro local.</p>
                    <hr />
                    <button class="btn btn-success fw-bold w-100" @onclick="EfetuarBackup" disabled="@isProcessing">
                        @if (isProcessing && currentAction == "BACKUP")
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {

                            <span><i class="oi oi-cloud-download me-1"></i> Baixar CONFIN_MXFC.db</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <!-- Card de Restore -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 text-center">
                    <i class="oi oi-data-transfer-upload text-danger mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold">Restore do Banco</h5>
                    <p class="text-muted small">Substitui o banco de dados atual no servidor por um arquivo de backup. Requer reinicialização da API.</p>
                    <hr />
                    <div class="position-relative overflow-hidden btn btn-outline-danger fw-bold w-100 d-inline-block">
                        @if (isProcessing && currentAction == "RESTORE")
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {

                            <span><i class="oi oi-warning me-1"></i> Sobrescrever Banco (.db)</span>
                        }
                        <InputFile OnChange="EfetuarRestore" accept=".db,.sqlite"
                                   style="position: absolute; top: 0; right: 0; min-width: 100%; min-height: 100%; opacity: 0; cursor: pointer;"
                                   disabled="@isProcessing" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-@statusType mt-4 py-3 fw-bold text-center">
            @statusMessage
        </div>
    }
</div>

@code {
    private bool isProcessing = false;
    private string currentAction = "";
    private string statusMessage = "";
    private string statusType = "info";

    private async Task EfetuarBackup()
    {
        isProcessing = true;
        currentAction = "BACKUP";
        statusMessage = "";

        try
        {
            var response = await Http.GetAsync("api/Admin/db-backup");
            if (response.IsSuccessStatusCode)
            {
                var fileStream = await response.Content.ReadAsStreamAsync();
                using var streamRef = new DotNetStreamReference(stream: fileStream);
                
                string dataAtual = DateTime.Now.ToString("yyyyMMdd_HHmm");
                await JS.InvokeVoidAsync("downloadFileFromStream", $"CONFIN_MXFC_BKP_{dataAtual}.db", streamRef);
                
                statusMessage = "Backup realizado e download iniciado com sucesso.";
                statusType = "success";
            }
            else
            {
                statusMessage = "Falha ao solicitar backup ao servidor.";
                statusType = "danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro de rede: {ex.Message}";
            statusType = "danger";
        }
        finally
        {
            isProcessing = false;
            currentAction = "";
        }
    }

    private async Task EfetuarRestore(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".db") && !file.Name.EndsWith(".sqlite"))
        {
            statusMessage = "Formato inválido. Selecione um arquivo de banco de dados do SQLite (.db ou .sqlite).";
            statusType = "warning";
            return;
        }

        isProcessing = true;
        currentAction = "RESTORE";
        statusMessage = "Enviando arquivo de banco de dados e processando substituição...";
        statusType = "warning";

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(50 * 1024 * 1024)); // Limite de 50MB para o DB
            content.Add(content: fileContent, name: "\"file\"", fileName: file.Name);

            var response = await Http.PostAsync("api/Admin/db-restore", content);
            
            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Banco de dados substituído com sucesso. A conexão atual foi encerrada. Realize o login novamente.";
                statusType = "success";
            }
            else
            {
                statusMessage = "Falha na substituição do arquivo de banco de dados. O arquivo pode estar em uso.";
                statusType = "danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro fatal no restore: {ex.Message}";
            statusType = "danger";
        }
        finally
        {
            isProcessing = false;
            currentAction = "";
        }
    }
}