@*
IDENTIFICAÇÃO DO CÓDIGO
======================================
ClienteForm.razor (Substitui EditClienteDialog.vb)
VERSÃO: 1.0.0 (Migração Web)
=======================================
*@
@page "/clientes/editar/{Id:int}"
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>@(Id == 0 ? "Novo Cliente" : "Editar Cliente")</PageTitle>

<div class="container-fluid py-3" style="max-width: 800px; margin: 0 auto;">
    
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-outline-secondary me-3" @onclick="Voltar">
            <i class="oi oi-arrow-left"></i> Voltar
        </button>
        <h3 style="color: #104E6E; font-weight: bold; margin: 0;">
            @(Id == 0 ? "Novo Cliente" : "Editar Cliente")
        </h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5 text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            Carregando dados...
        </div>
    }
    else if (clienteModel != null)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                
                <!-- Status Message -->
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert alert-@statusType py-2">@statusMessage</div>
                }

                <div class="row g-3">
                    
                    <!-- Busca CNPJ (Substitui a lógica da BrasilAPI) -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">CNPJ</label>
                        <div class="input-group">
                            <input type="text" class="form-control" @bind="clienteModel.CNPJ" @bind:event="oninput" placeholder="Somente números" maxlength="14" />
                            <button class="btn btn-primary" type="button" @onclick="BuscarCnpjNaApi" disabled="@isSearchingCnpj">
                                @if (isSearchingCnpj)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                }
                                else
                                {
                                    <span>Buscar Receita</span>
                                }
                            </button>
                        </div>
                        <div class="form-text">Digite os 14 números sem pontuação.</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Inscrição Estadual</label>
                        <input type="text" class="form-control" @bind="clienteModel.InscricaoEstadual" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Razão Social <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="clienteModel.RazaoSocial" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Endereço Completo</label>
                        <input type="text" class="form-control" @bind="clienteModel.Endereco" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">CEP</label>
                        <input type="text" class="form-control" @bind="clienteModel.CEP" placeholder="Somente números" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Telefone</label>
                        <input type="text" class="form-control" @bind="clienteModel.Telefone" placeholder="(XX) XXXXX-XXXX" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Responsável</label>
                        <input type="text" class="form-control" @bind="clienteModel.Responsavel" />
                    </div>

                </div>

                <hr class="mt-4 mb-3" />
                
                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary me-2" @onclick="Voltar">Cancelar</button>
                    <button class="btn btn-success px-4" @onclick="SalvarCliente" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Salvando...</span>
                        }
                        else
                        {
                            <i class="oi oi-check me-1"></i> <span>Salvar</span>
                        }
                    </button>
                </div>

            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    // Representa o modelo Cliente que trafega via JSON
    public class ClienteDto
    {
        public int Id { get; set; }
        public string RazaoSocial { get; set; } = string.Empty;
        public string CNPJ { get; set; } = string.Empty;
        public string InscricaoEstadual { get; set; } = string.Empty;
        public string Endereco { get; set; } = string.Empty;
        public string CEP { get; set; } = string.Empty;
        public string Telefone { get; set; } = string.Empty;
        public string Responsavel { get; set; } = string.Empty;
    }

    private ClienteDto? clienteModel;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isSearchingCnpj = false;
    private string statusMessage = "";
    private string statusType = "info";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Id == 0)
            {
                // Modo "Novo Cliente"
                clienteModel = new ClienteDto();
            }
            else
            {
                // Modo "Editar" - Busca na API (Ajuste o endpoint conforme sua API VB.NET)
                // OBS: O repositório ClienteRepo atual não tem método Obter(id).
                // Precisaremos garantir que a API devolva o cliente correto ou buscar da lista.
                var lista = await Http.GetFromJsonAsync<List<ClienteDto>>("api/Clientes");
                if (lista != null)
                {
                    clienteModel = lista.FirstOrDefault(c => c.Id == Id);
                }
                
                if (clienteModel == null)
                {
                    statusMessage = "Cliente não encontrado.";
                    statusType = "danger";
                }
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro de conexão: {ex.Message}";
            statusType = "danger";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string SomenteNumeros(string input)
    {
        if (string.IsNullOrEmpty(input)) return "";
        return Regex.Replace(input, @"[^\d]", "");
    }

    private async Task BuscarCnpjNaApi()
    {
        if (clienteModel == null) return;

        var cnpjLimpo = SomenteNumeros(clienteModel.CNPJ);
        
        if (cnpjLimpo.Length != 14)
        {
            statusMessage = "Aviso: O CNPJ deve conter exatamente 14 números.";
            statusType = "warning";
            return;
        }

        isSearchingCnpj = true;
        statusMessage = "Consultando Receita Federal...";
        statusType = "info";

        try
        {
            // Note que o Blazor Client-Side cuida do TLS automaticamente.
            var url = $"https://brasilapi.com.br/api/cnpj/v1/{cnpjLimpo}";
            
            // É importante usar um HttpClient limpo para APIs externas se o Http principal
            // estiver atrelado com BaseAddress="localhost:5000" no Program.cs.
            using var externalClient = new HttpClient();
            var response = await externalClient.GetFromJsonAsync<BrasilApiResponse>(url);

            if (response != null)
            {
                clienteModel.RazaoSocial = response.razao_social ?? "";
                
                if (string.IsNullOrWhiteSpace(clienteModel.RazaoSocial))
                    clienteModel.RazaoSocial = response.nome_fantasia ?? "";

                // Montagem do Endereço
                var enderecoArr = new List<string>();
                if (!string.IsNullOrEmpty(response.logradouro)) enderecoArr.Add(response.logradouro);
                if (!string.IsNullOrEmpty(response.numero)) enderecoArr.Add(response.numero);
                
                var finalString = string.Join(", ", enderecoArr);
                if (!string.IsNullOrEmpty(response.bairro)) finalString += $" - {response.bairro}";
                if (!string.IsNullOrEmpty(response.municipio)) finalString += $", {response.municipio}";
                if (!string.IsNullOrEmpty(response.uf)) finalString += $" - {response.uf}";

                clienteModel.Endereco = finalString;
                clienteModel.CEP = response.cep ?? "";
                clienteModel.Telefone = response.ddd_telefone_1 ?? "";

                statusMessage = "Dados preenchidos com sucesso.";
                statusType = "success";
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            statusMessage = "CNPJ não encontrado na base de dados.";
            statusType = "warning";
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro na consulta externa: {ex.Message}";
            statusType = "danger";
        }
        finally
        {
            isSearchingCnpj = false;
        }
    }

    private async Task SalvarCliente()
    {
        if (clienteModel == null) return;

        if (string.IsNullOrWhiteSpace(clienteModel.RazaoSocial))
        {
            statusMessage = "A Razão Social é um campo obrigatório.";
            statusType = "warning";
            return;
        }

        isSaving = true;
        statusMessage = "Salvando...";
        statusType = "info";

        try
        {
            // Limpa os dados antes de enviar (replicando a lógica do GetOnlyNumbers do VB)
            clienteModel.CNPJ = SomenteNumeros(clienteModel.CNPJ);
            clienteModel.CEP = SomenteNumeros(clienteModel.CEP);
            clienteModel.Telefone = SomenteNumeros(clienteModel.Telefone);

            // POST (criação e atualização usam a mesma rota na sua API atual)
            var response = await Http.PostAsJsonAsync("api/Clientes", clienteModel);
            
            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/clientes");
            }
            else
            {
                statusMessage = "Erro ao salvar no banco de dados.";
                statusType = "danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Falha de rede: {ex.Message}";
            statusType = "danger";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Voltar()
    {
        NavManager.NavigateTo("/clientes");
    }

    // Classe auxiliar para mapear o JSON da BrasilAPI
    private class BrasilApiResponse
    {
        public string? razao_social { get; set; }
        public string? nome_fantasia { get; set; }
        public string? logradouro { get; set; }
        public string? numero { get; set; }
        public string? bairro { get; set; }
        public string? municipio { get; set; }
        public string? uf { get; set; }
        public string? cep { get; set; }
        public string? ddd_telefone_1 { get; set; }
    }
}