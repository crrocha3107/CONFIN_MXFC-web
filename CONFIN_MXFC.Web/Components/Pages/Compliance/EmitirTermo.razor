@*
8. IDENTIFICAÇÃO DO CÓDIGO
======================================
Nome do arquivo: EmitirTermo.razor
Substitui: EmitirDeclaracaoForm.vb / .Designer.vb
VERSÃO: 1.0.0 (Migração Web - Compliance)
=======================================
*@
@page "/compliance/emitir"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Emitir Termo de Compliance</PageTitle>

<div class="container-fluid py-3" style="max-width: 600px; margin: 0 auto;">
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-white pt-4 pb-2 border-0">
            <h4 style="color: #104E6E; font-weight: bold;">
                <i class="oi oi-print me-2"></i> Emitir Termo de Compliance
            </h4>
            <p class="text-muted mb-0">Gere o documento oficial em PDF para a assinatura do colaborador.</p>
        </div>
        <div class="card-body p-4">
            
            @if (isLoading)
            {
                <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div> Carregando colaboradores...
                </div>
            }
            else
            {
                <div class="mb-4">
                    <label class="form-label fw-bold">Selecione o Colaborador (Ficha PF):</label>
                    <select class="form-select form-select-lg" @bind="funcSelecionadoReg">
                        @if (funcionarios != null)
                        {
                            foreach (var f in funcionarios)
                            {
                                <option value="@f.REG">@f.NomeCompleto</option>
                            }
                        }
                    </select>
                </div>

                <button class="btn btn-primary btn-lg w-100 fw-bold" @onclick="GerarPdf" disabled="@(isGenerating || funcSelecionadoReg == 0)">
                    @if (isGenerating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span> <span>Gerando PDF...</span>
                    }
                    else
                    {
                        <i class="oi oi-document me-2"></i> <span>Gerar PDF Timbrado</span>
                    }
                </button>
                
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert alert-danger mt-3 py-2">@statusMessage</div>
                }
            }
        </div>
    </div>
</div>

@code {
    public class FuncionarioDto { public int REG { get; set; } public string NomeCompleto { get; set; } = string.Empty; }

    private List<FuncionarioDto>? funcionarios;
    private int funcSelecionadoReg = 0;
    
    private bool isLoading = true;
    private bool isGenerating = false;
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // O backend deve retornar apenas funcionários Ativos, ordenados por NomeCompleto[cite: 30]
            funcionarios = await Http.GetFromJsonAsync<List<FuncionarioDto>>("api/Funcionarios/ativos");
            if (funcionarios != null && funcionarios.Any())
            {
                funcSelecionadoReg = funcionarios.First().REG;
            }
        }
        catch (Exception ex)
        {
            statusMessage = "Erro ao carregar a lista de colaboradores.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GerarPdf()
    {
        if (funcSelecionadoReg == 0) return;
        
        isGenerating = true;
        statusMessage = "";
        
        try
        {
            var func = funcionarios?.FirstOrDefault(f => f.REG == funcSelecionadoReg);
            string safeName = func?.NomeCompleto.Replace(" ", "_") ?? "Colaborador";
            
            // Chama a API que usa o ComplianceService.vb no Backend[cite: 30]
            var response = await Http.PostAsync($"api/Compliance/gerar-termo/{funcSelecionadoReg}", null);
            
            if (response.IsSuccessStatusCode)
            {
                var fileStream = await response.Content.ReadAsStreamAsync();
                using var streamRef = new DotNetStreamReference(stream: fileStream);
                
                // Reaproveita a função JS que injetamos na página de relatórios (ou coloque-a no index.html/App.razor)
                await JS.InvokeVoidAsync("downloadFileFromStream", $"Termo_Compliance_{safeName}.pdf", streamRef);
            }
            else
            {
                statusMessage = "Falha ao gerar o documento no servidor.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro de rede: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }
}