@*
8. IDENTIFICAÇÃO DO CÓDIGO
======================================
Nome do arquivo: RelatorioColaboradores.razor
Substitui: RelatorioColaboradoresForm.vb / .Designer.vb
VERSÃO: 1.0.0 (Migração Web - Relatórios)
DATA: 06/05/2026
=======================================
*@
@page "/relatorios/colaboradores"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Relatório de Colaboradores</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 style="color: #104E6E; font-weight: bold; margin: 0;">Relatório Analítico de Colaboradores</h3>
        
        <!-- Botões de Exportação -->
        <div>
            <button class="btn btn-outline-success fw-bold me-2" @onclick="ExportarExcel" disabled="@(!PodeExportar)">
                <i class="oi oi-spreadsheet me-1"></i> Exportar Excel
            </button>
            <button class="btn btn-outline-danger fw-bold" @onclick="ExportarPdf" disabled="@(!PodeExportar)">
                <i class="oi oi-document me-1"></i> Exportar PDF (A4)
            </button>
        </div>
    </div>

    <!-- Painel de Filtros -->
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-3">
            
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-warning py-2 mb-3">@statusMessage</div>
            }

            <div class="row g-3 align-items-end">
                
                <!-- Filtro de Colaborador -->
                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-1">
                        <label class="form-label fw-bold m-0">Colaborador (PJ)</label>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" id="chkTodosColab" @bind="mostrarTodosColabs" @bind:after="OnFiltroColabChanged">
                            <label class="form-check-label text-muted" style="font-size: 0.85rem;" for="chkTodosColab">Todos</label>
                        </div>
                    </div>
                    <select class="form-select" @bind="colabSelecionadoId" @bind:after="AtualizarRelatorio" disabled="@mostrarTodosColabs">
                        @if (colaboradores != null)
                        {
                            foreach (var c in colaboradores)
                            {
                                <option value="@c.Id">@c.NomeEmpresa</option>
                            }
                        }
                    </select>
                </div>

                <!-- Filtro de Período -->
                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-1">
                        <label class="form-label fw-bold m-0">Período</label>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" id="chkTodosPeriodos" @bind="mostrarTodosPeriodos" @bind:after="OnFiltroPeriodoChanged">
                            <label class="form-check-label text-muted" style="font-size: 0.85rem;" for="chkTodosPeriodos">Histórico Completo (1 Colab)</label>
                        </div>
                    </div>
                    <div class="input-group">
                        <select class="form-select" @bind="mesSelecionado" @bind:after="AtualizarRelatorio" disabled="@mostrarTodosPeriodos">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@i.ToString("00")</option>
                            }
                        </select>
                        <select class="form-select" @bind="anoSelecionado" @bind:after="AtualizarRelatorio" disabled="@mostrarTodosPeriodos">
                            @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year + 1; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-2 text-end">
                    <button class="btn btn-primary w-100" @onclick="AtualizarRelatorio">
                        <i class="oi oi-magnifying-glass"></i> Processar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela de Resultados -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-5 text-center text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div> Gerando relatório...
                </div>
            }
            else if (listaRelatorio == null || !listaRelatorio.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="oi oi-list fs-1 d-block mb-2 text-light"></i>
                    Sem dados para os filtros informados.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 50px;" class="text-center">
                                    <input type="checkbox" class="form-check-input" @bind="selecionarTodos" @bind:after="AlternarSelecaoTodos" />
                                </th>
                                <th>Colaborador</th>
                                <th>Mês/Ano</th>
                                <th class="text-end">Total de Gastos</th>
                                <th class="text-end">Valor da Nota Fiscal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in listaRelatorio)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input" @bind="item.Selecionado" />
                                    </td>
                                    <td class="fw-bold">@item.Colaborador</td>
                                    <td>@item.Periodo</td>
                                    <td class="text-end">@item.TotalGastos.ToString("C2")</td>
                                    <td class="text-end text-success fw-bold">@item.ValorNotaFiscal.ToString("C2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-group-divider">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">TOTAIS (Exibição):</td>
                                <td class="text-end fw-bold">@listaRelatorio.Sum(x => x.TotalGastos).ToString("C2")</td>
                                <td class="text-end fw-bold text-success">@listaRelatorio.Sum(x => x.ValorNotaFiscal).ToString("C2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Script embutido para download de arquivo via ByteArray -->
<script>
    window.downloadFileFromStream = async (fileName, contentStreamReference) => {
        const arrayBuffer = await contentStreamReference.arrayBuffer();
        const blob = new Blob([arrayBuffer]);
        const url = URL.createObjectURL(blob);
        const anchorElement = document.createElement('a');
        anchorElement.href = url;
        anchorElement.download = fileName ?? '';
        anchorElement.click();
        anchorElement.remove();
        URL.revokeObjectURL(url);
    }
</script>

@code {
    public class ColaboradorDto { public int Id { get; set; } public string NomeEmpresa { get; set; } = string.Empty; }
    
    public class RelatorioLinhaDto
    {
        public bool Selecionado { get; set; } = true; // Equivale à coluna de checkbox gerada via código no WinForms
        public string Colaborador { get; set; } = string.Empty;
        public string Periodo { get; set; } = string.Empty;
        public decimal TotalGastos { get; set; }
        public decimal ValorNotaFiscal { get; set; }
        public int Mes { get; set; }
        public int Ano { get; set; }
    }

    private List<ColaboradorDto>? colaboradores;
    private List<RelatorioLinhaDto>? listaRelatorio;
    
    private int colabSelecionadoId = 0;
    private int mesSelecionado = DateTime.Now.Month;
    private int anoSelecionado = DateTime.Now.Year;
    
    private bool mostrarTodosColabs = false;
    private bool mostrarTodosPeriodos = false;
    private bool isLoading = false;
    private string statusMessage = "";
    
    private bool selecionarTodos = true;
    private bool PodeExportar => listaRelatorio != null && listaRelatorio.Any(x => x.Selecionado);

    protected override async Task OnInitializedAsync()
    {
        colaboradores = await Http.GetFromJsonAsync<List<ColaboradorDto>>("api/Colaboradores");
        if (colaboradores != null && colaboradores.Any())
        {
            colabSelecionadoId = colaboradores.First().Id;
            await AtualizarRelatorio();
        }
    }

    // Regra de Negócio: Não permite marcar "Todos os Períodos" se "Todos os Colaboradores" estiver marcado
    private void OnFiltroColabChanged()
    {
        if (mostrarTodosColabs && mostrarTodosPeriodos)
        {
            mostrarTodosPeriodos = false;
        }
        _ = AtualizarRelatorio();
    }

    private void OnFiltroPeriodoChanged()
    {
        if (mostrarTodosPeriodos && mostrarTodosColabs)
        {
            statusMessage = "Para ver todos os períodos, o sistema desmarcou a seleção de 'Todos os Colaboradores'.";
            mostrarTodosColabs = false;
        }
        else
        {
            statusMessage = "";
        }
        _ = AtualizarRelatorio();
    }

    private async Task AtualizarRelatorio()
    {
        isLoading = true;
        try
        {
            var queryColab = mostrarTodosColabs ? "0" : colabSelecionadoId.ToString();
            var queryMes = mostrarTodosPeriodos ? "0" : mesSelecionado.ToString();
            var queryAno = mostrarTodosPeriodos ? "0" : anoSelecionado.ToString();

            // Chamada para a API que orquestra a soma dos gastos e NFs (antiga lógica do WinForms)
            listaRelatorio = await Http.GetFromJsonAsync<List<RelatorioLinhaDto>>(
                $"api/Relatorios/colaboradores?colabId={queryColab}&mes={queryMes}&ano={queryAno}");
                
            selecionarTodos = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao gerar relatório: {ex.Message}");
            listaRelatorio = new List<RelatorioLinhaDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AlternarSelecaoTodos()
    {
        if (listaRelatorio != null)
        {
            foreach (var item in listaRelatorio)
            {
                item.Selecionado = selecionarTodos;
            }
        }
    }

    private async Task ExportarExcel()
    {
        var selecionados = listaRelatorio?.Where(x => x.Selecionado).ToList();
        if (selecionados == null || !selecionados.Any()) return;

        // O backend gera o .xlsx usando ClosedXML e retorna os bytes do arquivo
        var response = await Http.PostAsJsonAsync("api/Exportacao/excel/colaboradores", selecionados);
        if (response.IsSuccessStatusCode)
        {
            var fileStream = await response.Content.ReadAsStreamAsync();
            using var streamRef = new DotNetStreamReference(stream: fileStream);
            await JS.InvokeVoidAsync("downloadFileFromStream", "RelatorioColaboradores.xlsx", streamRef);
        }
    }

    private async Task ExportarPdf()
    {
        var selecionados = listaRelatorio?.Where(x => x.Selecionado).ToList();
        if (selecionados == null || !selecionados.Any()) return;

        var dtoParams = new
        {
            Itens = selecionados,
            Titulo = mostrarTodosPeriodos
                ? $"Histórico Completo - {colaboradores?.FirstOrDefault(c => c.Id == colabSelecionadoId)?.NomeEmpresa}"
                : $"Período: {mesSelecionado:00}/{anoSelecionado}"
        };

        // O backend gera o PDF usando iTextSharp e a Folha Timbrada do servidor, retornando os bytes
        var response = await Http.PostAsJsonAsync("api/Exportacao/pdf/colaboradores", dtoParams);
        if (response.IsSuccessStatusCode)
        {
            var fileStream = await response.Content.ReadAsStreamAsync();
            using var streamRef = new DotNetStreamReference(stream: fileStream);
            await JS.InvokeVoidAsync("downloadFileFromStream", "RelatorioColaboradores.pdf", streamRef);
        }
    }
}