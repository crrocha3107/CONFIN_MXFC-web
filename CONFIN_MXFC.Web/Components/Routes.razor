@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using global::CONFIN_MXFC.Web.Security

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @* Chamada direta ao componente de redirecionamento *@
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <div class="text-center p-5 mt-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 fw-bold text-muted">Acessando ambiente seguro MXFC...</p>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não Encontrado</PageTitle>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <div class="alert alert-warning m-5 shadow-sm">
                    <strong>Aviso:</strong> A página solicitada não existe ou o acesso foi negado.
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>